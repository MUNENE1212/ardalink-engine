# ArdaLink Engine — environment template
# Copy to .env and fill in your real values. Never commit .env.

# Server
ARDALINK_HOST=0.0.0.0
ARDALINK_PORT=5001
ARDALINK_LOG_LEVEL=INFO

# Database (shared with ardalink-api; this service uses gis_engine schema)
DATABASE_URL=postgresql://user:password@localhost:5432/ardalink
GIS_ENGINE_SCHEMA=gis_engine

# Google Earth Engine
# Required for live satellite ingestion. Engine serves baseline data without it.
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_PRIVATE_KEY={"type":"service_account","project_id":"...","private_key":"..."}
GEE_PROJECT=your-google-cloud-project

# Azure OpenAI (optional — for analytical tasks)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_TIMEOUT_SECONDS=30

# Grid configuration
GRID_RESOLUTION_M=250
GRID_CHUNK_SIZE=2000

# Scheduler
INGEST_SCHEDULER_ENABLED=1
INGEST_CHECK_INTERVAL_SECONDS=900
INGEST_STARTUP_DELAY_SECONDS=120
INGEST_MIN_COVERAGE_FRACTION=0.5
INGEST_NIGHT_ONLY=1
INGEST_LOCAL_UTC_OFFSET_HOURS=3
INGEST_NIGHT_START_HOUR=1
INGEST_NIGHT_END_HOUR=5
INGEST_INTERVAL_STATIC_HOURS=168
INGEST_INTERVAL_VEGETATION_HOURS=168
INGEST_INTERVAL_PROTEIN_HOURS=168
INGEST_INTERVAL_CLIMATE_HOURS=168
INGEST_INTERVAL_SOIL_HOURS=168

# Routing / obstacles
ISIOLO_BBOX_S=-0.6
ISIOLO_BBOX_W=36.5
ISIOLO_BBOX_N=2.9
ISIOLO_BBOX_E=39.6
OVERPASS_URL=https://overpass-api.de/api/interpreter
OVERPASS_TIMEOUT_SECONDS=90
OBSTACLE_CACHE_TTL_SECONDS=21600

# Multi-tenant
# Shared HMAC secret with ardalink-api. Empty in dev disables attestation.
TENANT_ATTESTATION_SECRET=